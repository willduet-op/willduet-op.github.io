    href: "/blogs/how-to-optimize-slow-power-bi-reports/",
    image: "/bi.webp",
    category: "Power BI performance",
    readTime: "9 min read",
  },
  {
    title: "How to Create Automated Business Reports That Actually Help",
    description:
      "A founder-friendly guide to automated reporting, BI dashboards, KPI definitions, data sources, and scheduled refreshes.",
    href: "/blogs/how-to-create-automated-business-reports/",
    image: "/dashboard.jpg",
    category: "Automated reporting",
    readTime: "9 min read",
  },
  {
    title: "Database vs Data Warehouse: What Is the Difference?",
    description:
      "A plain-English guide to databases, data warehouses, OLTP, OLAP, reporting, and when a business needs each one.",
    href: "/blogs/database-vs-data-warehouse/",
    image: "/de.webp",
    category: "Data fundamentals",
    readTime: "8 min read",
  },
];
const hasPosts = posts.length > 0;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "WILLDUET Blogs",
  url: "https://willduet.com/blogs/",
  description,
  blogPost: posts.map((post) => ({
    "@type": "BlogPosting",
    headline: post.title,
    url: `https://willduet.com${post.href}`,
    description: post.description,
    image: `https://willduet.com${post.image}`,
  })),
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/blogs/"
  image="/dashboard.jpg"
  structuredData={structuredData}
>
  <Header />

  <main>
    <section class="blogs-hero reveal">
      <div class="container blogs-hero-inner">
        <div class="blogs-hero-copy">
          <span class="eyebrow">WILLDUET resources</span>
          <h1 class="blogs-title">Blogs for better dashboards, data models, and analytics workflows</h1>
          <p class="muted blogs-subtitle">
            Articles on business intelligence, data foundations, reporting quality, and analytics workflows.
          </p>
        </div>
      </div>
    </section>

    <div class="container blogs-wrap">
      <section class="section reveal" style="padding:22px 0;">
        <div class="blogs-section-head">
          <h2 class="section-title">Latest posts</h2>
          <p class="muted">Practical explanations for business leaders, analysts, and teams improving reporting systems.</p>
        </div>

        {hasPosts ? (
          <div class="blog-grid">
            {posts.map((post, index) => (
              <a class={`card blog-card reveal-delay-${Math.min(index + 1, 4)}`} href={post.href}>
                <img src={post.image} alt="" loading="lazy" decoding="async" />
                <div class="blog-card-body">
                  <div class="blog-meta">
                    <span>{post.category}</span>
                    <span>{post.readTime}</span>
                  </div>
                  <h3>{post.title}</h3>
                  <p class="muted">{post.description}</p>
                  <span class="blog-link">Read article</span>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="card blogs-empty">
            <img src="/project.jpeg" alt="" loading="lazy" decoding="async" />
            <div class="blogs-empty-copy">
              <h2>No blog posts published yet</h2>
              <p class="muted">
                Service pages and landing pages are intentionally excluded from this section. New articles will appear here once they are published.
              </p>
              <div class="blogs-empty-actions">
                <a class="btn btn-primary" href="/services/">View services</a>
                <a class="btn" href="/contact/">Contact WILLDUET</a>
              </div>
            </div>
          </div>
        )}
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .blogs-hero{
    min-height: 44vh;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--border);
    background:
      linear-gradient(115deg, rgba(7,22,44,.94), rgba(7,22,44,.68)),
      url("/project.jpeg") center/cover no-repeat;
  }
  .blogs-hero-inner{
    padding: clamp(42px, 6vw, 78px) 0;
  }
  .blogs-hero-copy{
    max-width: 860px;
  }
  .blogs-title{
    margin: 16px 0 12px;
    font-size: clamp(34px, 5vw, 58px);
    line-height: 1.04;
    letter-spacing: .01em;
  }
  .blogs-subtitle{
    margin: 0;
    max-width: 720px;
    font-size: clamp(16px, 1.2vw, 19px);
    line-height: 1.7;
  }
  .blogs-wrap{
    padding: 34px 0 42px;
  }
  .blogs-empty{
    display: grid;
    overflow: hidden;
  }
  .blogs-empty img,
  .blog-card img{
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .blogs-empty img{
    min-height: 260px;
  }
  .blogs-empty-copy{
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 12px;
    padding: clamp(20px, 3vw, 34px);
  }
  .blogs-empty-copy h2,
  .blog-card h3{
    margin: 0;
    line-height: 1.16;
  }
  .blogs-empty-copy h2{
    font-size: clamp(26px, 3vw, 38px);
  }
  .blogs-empty-copy p,
  .blog-card p{
    margin: 0;
    line-height: 1.65;
  }
  .blogs-empty-actions{
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 6px;
  }
  .blog-meta{
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    color: var(--muted);
    font-size: 13px;
    font-weight: 700;
  }
  .blog-meta span{
    display: inline-flex;
    align-items: center;
  }
  .blog-meta span + span::before{
    content: "";
    width: 5px;
    height: 5px;
    margin-right: 10px;
    border-radius: 999px;
    background: var(--primary);
  }
  .blog-link{
    color: #7ad8ff;
    font-weight: 800;
  }
  .blogs-section-head{
    display: grid;
    gap: 4px;
    max-width: 760px;
    margin-bottom: 16px;
  }
  .blogs-section-head p{
    margin: 0;
    line-height: 1.65;
  }
  .blog-grid{
    display: grid;
    gap: 14px;
  }
  .blog-card{
    overflow: hidden;
    display: grid;
    grid-template-rows: 190px 1fr;
  }
  .blog-card-body{
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 18px;
  }

  @media (min-width: 800px){
    .blogs-empty{
      grid-template-columns: .95fr 1.05fr;
      min-height: 360px;
    }
    .blog-grid{
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1080px){
    .blog-grid{
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
