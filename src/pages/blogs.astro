  },
  {
    title: "Power BI Governance: How to Scale Power BI Across Your Organization",
    description:
      "Learn how to build a Power BI governance strategy that supports self-service reporting without losing control over data and metrics.",
    href: "/blogs/power-bi-governance/",
    image: "/blogs/power-bi-governance.webp",
