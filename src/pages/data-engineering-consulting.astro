---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Data Engineering Consulting for Analytics | WILLDUET";
const description =
  "Data engineering consulting for US businesses that need reliable data pipelines, analytics-ready tables, cleaner reporting data, and less manual work.";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Data Engineering Consulting",
  provider: { "@type": "ProfessionalService", name: "WILLDUET", url: "https://willduet.com/" },
  areaServed: { "@type": "Country", name: "United States" },
  serviceType: "Data engineering consulting",
  url: "https://willduet.com/data-engineering-consulting/",
  description,
};
---
<BaseLayout title={title} description={description} canonicalPath="/data-engineering-consulting/" image="/de.webp" structuredData={structuredData}>
  <Header />
  <main style="padding:0 0 22px;">
    <section class="hero-full reveal">
      <div class="container" style="padding:42px 0;">
        <div class="hero-panel">
          <div class="hero-copy">
            <h1 class="hero-title">Data Engineering Consulting for Analytics</h1>
            <p class="muted hero-subtitle">Create reliable pipelines and analytics-ready data so dashboards stop depending on manual exports and spreadsheet cleanup.</p>
          </div>
          <div class="hero-actions">
            <a class="btn btn-primary" href="/contact">Discuss your data pipeline</a>
            <a class="btn" href="/analytics-engineering-consulting/">Analytics engineering</a>
          </div>
        </div>
      </div>
    </section>

    <div class="container" style="padding-top:40px;">
      <section class="section reveal section-band">
        <div class="split service-section">
          <div class="service-copy">
            <h2 class="section-title">Cleaner data for better reporting</h2>
            <p class="muted">Analytics fails when source data is scattered, inconsistent, or moved manually. We help US businesses connect systems, transform data, and create maintainable tables for BI and analysis.</p>
            <p class="muted">Projects can include data ingestion, scheduled refreshes, table modeling, documentation, quality checks, and pipeline troubleshooting.</p>
          </div>
          <img src="/de.webp" alt="Data engineering pipeline for analytics and BI reporting" class="service-image" loading="lazy" decoding="async" />
        </div>
      </section>

      <section class="section reveal section-band alt">
        <h2 class="section-title">What we improve</h2>
        <div class="grid grid-3">
          <div class="card" style="padding:18px;"><h3 style="margin:0 0 8px;">Manual reporting</h3><p class="muted" style="margin:0;line-height:1.6;">Replace recurring spreadsheet exports with scheduled, repeatable data flows.</p></div>
          <div class="card" style="padding:18px;"><h3 style="margin:0 0 8px;">Broken data trust</h3><p class="muted" style="margin:0;line-height:1.6;">Create consistent source logic so teams stop arguing over which number is right.</p></div>
          <div class="card" style="padding:18px;"><h3 style="margin:0 0 8px;">Slow analytics delivery</h3><p class="muted" style="margin:0;line-height:1.6;">Structure the data foundation so new reports are easier to build and maintain.</p></div>
        </div>
      </section>

      <section class="section reveal" style="padding:18px 0;">
        <div class="card" style="padding:18px;display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;">
          <div><h2 style="margin:0 0 8px;">Need cleaner analytics data?</h2><p class="muted" style="margin:0;max-width:720px;line-height:1.6;">Tell us your data sources and reporting pain points, and we will recommend a practical pipeline plan.</p></div>
          <a class="btn btn-primary" href="/contact">Plan a data pipeline</a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
