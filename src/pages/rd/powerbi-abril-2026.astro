---
import "../../styles/rd-powerbi.css";
import BaseLayout from "../../layouts/BaseLayout.astro";

const WHATSAPP_NUMBER = "19149437575";
const waUrl = (message) => `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(message)}`;
const WA_MSG_RESERVA = "Hola, quiero reservar mi cupo para el curso de Power BI.";
const WA_MSG_DETALLES_CUPO = "Hola, me interesa el curso de Power BI. ¿Me puedes dar detalles del cupo y la forma de pago?";
const WA_MSG_PROGRAMA = "Me interesa el curso de Power BI, ¿me puedes enviar el programa?";
const WA_MSG_PREGUNTAS = "Hola, tengo algunas preguntas sobre el curso de Power BI.";
const WA_MSG_INSCRIBIRME = "Hola, me interesa el curso de Power BI y quiero inscribirme.";
const WA_MSG_APRENDER = "Hola, quiero aprender Power BI. ¿Me ayudas a reservar mi cupo?";
const waReservaUrl = waUrl(WA_MSG_RESERVA);
const waDetallesUrl = waUrl(WA_MSG_DETALLES_CUPO);
const waProgramaUrl = waUrl(WA_MSG_PROGRAMA);
const waPreguntasUrl = waUrl(WA_MSG_PREGUNTAS);
const waInscribirUrl = waUrl(WA_MSG_INSCRIBIRME);
const waAprenderUrl = waUrl(WA_MSG_APRENDER);
const VIDEO_SRC = "/rd/vid-landing.mp4";
---

<BaseLayout title="Curso Power BI para Analistas | RD" description="Curso de Power BI en vivo en República Dominicana.">
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>

  <main class="rd-wrap">
    <!-- HERO -->
    <section class="rd-hero">
      <div class="container rd-grid">
        <div>
          <div class="rd-pill">Cupos limitados · Solo 20 participantes</div>
          <h1 class="rd-title">Power BI para Analistas que quieren resultados reales</h1>
          <p class="rd-sub">
            Pasa de Excel a dashboards que sí responden preguntas de negocio. Clases en vivo los sábados
            10:00am a 12:00pm (RD). Del 18 de Abril al 30 de Mayo 2026.
          </p>

          <div class="rd-highlights">
            <div class="card rd-mini">
              <div class="rd-mini-title">Clases en vivo</div>
              <div class="rd-mini-text">Sábados 10am a 12pm (RD)</div>
            </div>
            <div class="card rd-mini">
              <div class="rd-mini-title">Acompañamiento personalizado</div>
              <div class="rd-mini-text">Feedback directo durante el curso</div>
            </div>
            <div class="card rd-mini">
              <div class="rd-mini-title">Proyecto final</div>
              <div class="rd-mini-text">Listo para tu portafolio</div>
            </div>
          </div>

          <div class="rd-cta">
            <a class="btn btn-primary" href={waReservaUrl} target="_blank" rel="noopener">Reservar cupo por WhatsApp</a>
            <a class="btn" href="#inversion">Ver inversión</a>
          </div>

          <div class="rd-trust">
            <div>✅ Enfocado en analistas</div>
            <div>✅ Ejercicios guiados</div>
            <div>✅ Proyecto aplicable</div>
          </div>
        </div>

        <div class="rd-media">
          <div class="rd-video-frame" aria-label="Video de presentación del curso">
            <div class="rd-video-badge">Video 60s</div>
            <video class="rd-video" autoplay muted playsinline loop preload="metadata">
              <source src={VIDEO_SRC} type="video/mp4" />
              Tu navegador no soporta video HTML5.
            </video>
            <button class="rd-video-sound" type="button" aria-label="Activar sonido">
              🔇
            </button>
          </div>
          <div class="rd-media-frame">
            <div class="rd-media-title">Un ejemplo real de lo que podrás hacer</div>
            <img src="/rd/demo-dashboard.png" alt="Ejemplo de dashboard creado en Power BI" />
          </div>
          <div style="display:flex;justify-content:center;">
            <a class="btn btn-primary" href={waAprenderUrl} target="_blank" rel="noopener">¡Quiero aprender!</a>
          </div>
        </div>
      </div>
    </section>

    <!-- DIRIGIDO A -->
    <section class="rd-section" id="dirigido">
      <div class="container">
        <div class="rd-head">
          <h2>Dirigido a</h2>
          <p>Ideal si ya entiendes Excel (básico o más) y quieres avanzar a BI con una guía clara.</p>
        </div>

        <div class="rd-grid-3">
          <div class="card rd-card-pad">
            <h3 style="margin:0 0 8px;">Personas con base en Excel</h3>
            <p class="muted" style="margin:0;line-height:1.6;">Que quieren avanzar a Power BI paso a paso, con práctica real.</p>
          </div>
          <div class="card rd-card-pad">
            <h3 style="margin:0 0 8px;">Profesionales</h3>
            <p class="muted" style="margin:0;line-height:1.6;">Que desean aprender a analizar y presentar datos de forma profesional.</p>
          </div>
          <div class="card rd-card-pad">
            <h3 style="margin:0 0 8px;">Quienes quieren iniciar o formalizar</h3>
            <p class="muted" style="margin:0;line-height:1.6;">Su carrera en análisis de datos con un proyecto final para su portafolio.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- APRENDERAS -->
    <section class="rd-section rd-section-alt" id="aprenderas">
      <div class="container">
        <div class="rd-head">
          <h2>Aprenderás a</h2>
          <p>Con enfoque analítico y aplicable a escenarios reales.</p>
        </div>

        <div class="rd-list">
          <div class="rd-item">Diseñar dashboards que impresionen y apoyen decisiones reales.</div>
          <div class="rd-item">Conectar datos desde Excel, CSV, bases de datos y carpetas.</div>
          <div class="rd-item">Limpiar y transformar datos con Power Query sin enredarte.</div>
          <div class="rd-item">Modelar datos y relaciones como se hace en la industria.</div>
          <div class="rd-item">Crear medidas DAX, KPIs y métricas que el negocio entiende.</div>
          <div class="rd-item">Pensar y preguntar como analista antes de construir reportes.</div>
        </div>

        <div style="margin-top:18px;max-width:520px;display:grid;gap:10px;">
          <a class="btn btn-primary" href={waDetallesUrl} target="_blank" rel="noopener">Quiero detalles del cupo</a>
          <div class="muted" style="font-size:13px;line-height:1.5;">Te respondo con detalles del cupo y forma de pago.</div>
        </div>
      </div>
    </section>

    <!-- PROGRAMA -->
    <section class="rd-section" id="programa">
      <div class="container">
        <div class="rd-head">
          <h2>Programa de clases</h2>
          <p>7 clases (una opcional) + proyecto final.</p>
        </div>

        <div class="rd-timeline">
          <div class="rd-t">
            <div class="rd-num">1</div>
            <div>
              <div class="rd-ttitle">Rol del analista de datos y estructura de solución BI</div>
              <div class="rd-ttext">Qué construir, por qué y cómo hacerlo bien desde el inicio.</div>
            </div>
          </div>

          <div class="rd-t">
            <div class="rd-num">2</div>
            <div>
              <div class="rd-ttitle">Conexión a fuentes de datos</div>
              <div class="rd-ttext">Excel, CSV, bases de datos y carpetas.</div>
            </div>
          </div>

          <div class="rd-t">
            <div class="rd-num">3</div>
            <div>
              <div class="rd-ttitle">Limpieza y transformación con Power Query</div>
              <div class="rd-ttext">Preparación de datos para análisis sin dolor.</div>
            </div>
          </div>

          <div class="rd-t">
            <div class="rd-num">4</div>
            <div>
              <div class="rd-ttitle">Modelado de datos y relaciones</div>
              <div class="rd-ttext">Modelo estrella, buenas prácticas y errores comunes.</div>
            </div>
          </div>

          <div class="rd-t">
            <div class="rd-num">5</div>
            <div>
              <div class="rd-ttitle">Medidas, DAX y creación de KPIs</div>
              <div class="rd-ttext">Medidas, contexto de filtro y KPIs útiles al negocio.</div>
            </div>
          </div>

          <div class="rd-t">
            <div class="rd-num">6</div>
            <div>
              <div class="rd-ttitle">Visualización, dashboards y publicación en Power BI Service</div>
              <div class="rd-ttext">Diseño, narrativa y entrega profesional.</div>
            </div>
          </div>

          <div class="rd-t">
            <div class="rd-num">7</div>
            <div>
              <div class="rd-ttitle">Opcional: CV, portafolio y búsqueda de empleo</div>
              <div class="rd-ttext">Cómo presentar tu trabajo y destacar.</div>
            </div>
          </div>

          <div class="rd-t rd-t-final">
            <div class="rd-num">★</div>
            <div>
              <div class="rd-ttitle">Proyecto final</div>
              <div class="rd-ttext">Un proyecto completo para mostrar en tu portafolio.</div>
            </div>
          </div>
        </div>

        <div style="margin-top:18px;max-width:520px;display:grid;gap:10px;">
          <a class="btn btn-primary" href={waProgramaUrl} target="_blank" rel="noopener">Quiero el programa por WhatsApp</a>
          <div class="muted" style="font-size:13px;line-height:1.5;">Te lo envío y coordinamos tu inscripción.</div>
        </div>
      </div>
    </section>

    <!-- INVERSION -->
    <section class="rd-section rd-section-alt" id="inversion">
      <div class="container">
        <div class="rd-pricing">
          <div>
            <h2 style="margin:0 0 10px;">Inversión</h2>
            <p class="rd-lead">RD$ 5,000</p>

            <ul class="rd-bullets">
              <li>Acompañamiento personalizado.</li>
              <li>Clases en vivo y práctica guiada.</li>
              <li>Proyecto final para portafolio.</li>
              <li>Cupos limitados (20).</li>
            </ul>

            <div style="margin-top:18px;max-width:520px;display:grid;gap:10px;">
              <a class="btn btn-primary" href={waReservaUrl} target="_blank" rel="noopener">Reservar mi cupo por WhatsApp</a>
              <div class="muted" style="font-size:13px;line-height:1.5;">Se abre WhatsApp con el mensaje listo para enviar.</div>
            </div>
          </div>

          <div class="card rd-card-pad">
            <h3 style="margin:0 0 8px;">Detalles rápidos</h3>

            <div class="rd-kv">
              <div class="rd-kv-row"><span>Modalidad</span><span>En vivo</span></div>
              <div class="rd-kv-row"><span>Horario</span><span>Sábados 10am a 12pm (RD)</span></div>
              <div class="rd-kv-row"><span>Fechas</span><span>18 Abril al 30 Mayo 2026</span></div>
              <div class="rd-kv-row"><span>Incluye</span><span>Guía personalizada y proyecto para portafolio.</span></div>
            </div>

            <div class="muted" style="margin-top:12px;line-height:1.6;font-size:14px;">
              Si tienes preguntas antes de pagar, escríbeme y te respondo rápido.
            </div>

            <div style="margin-top:12px;">
              <a class="btn" href={waPreguntasUrl} target="_blank" rel="noopener">Tengo preguntas, escríbeme</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="rd-section" id="faq">
      <div class="container">
        <div class="rd-head">
          <h2>Preguntas frecuentes</h2>
          <p>Respuestas rápidas para que tomes la decisión sin estrés.</p>
        </div>

        <div class="rd-faq">
          <details class="rd-faq-item">
            <summary>¿Necesito experiencia previa en Power BI?</summary>
            <div class="rd-faq-body">
              No. Lo ideal es tener base en Excel. Te llevo paso a paso desde lo esencial hasta publicar en Power BI Service.
            </div>
          </details>

          <details class="rd-faq-item">
            <summary>¿Qué necesito para participar?</summary>
            <div class="rd-faq-body">
              Una laptop, internet estable y ganas de practicar. Recomendado: Excel básico o más.
            </div>
          </details>

          <details class="rd-faq-item">
            <summary>¿Cómo reservo el cupo?</summary>
            <div class="rd-faq-body">
              Haz clic en el botón "Reservar cupo por WhatsApp", envía el mensaje y te indico los pasos de inscripción y pago.
            </div>
          </details>

          <details class="rd-faq-item">
            <summary>¿Qué pasa si no puedo asistir a un sábado?</summary>
            <div class="rd-faq-body">
              No te preocupes, tendrás videos de cada clase y te respondemos tus preguntas por WhatsApp.
            </div>
          </details>
        </div>

        <div style="margin-top:18px;max-width:520px;">
          <a class="btn btn-primary" href={waReservaUrl} target="_blank" rel="noopener">Reservar cupo por WhatsApp</a>
        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="rd-final">
      <div class="container rd-final-inner">
        <div>
          <h2>¿Listo para dominar Power BI como analista?</h2>
          <p>Escríbeme ahora y te confirmo disponibilidad de cupo y forma de inscripción.</p>
        </div>
        <a class="btn btn-primary" href={waInscribirUrl} target="_blank" rel="noopener">Enviar WhatsApp ahora</a>
      </div>
    </section>
  </main>
  <script>
    const video = document.querySelector(".rd-video");
    const soundBtn = document.querySelector(".rd-video-sound");
    if (video && soundBtn) {
      soundBtn.addEventListener("click", () => {
        video.muted = !video.muted;
        soundBtn.textContent = video.muted ? "🔇" : "🔊";
        soundBtn.setAttribute("aria-label", video.muted ? "Activar sonido" : "Silenciar sonido");
      });
    }
  </script>

<script is:inline>
document.addEventListener('DOMContentLoaded', () => {
  if (typeof fbq !== 'function') return;

  // Selecciona TODOS los links que van a WhatsApp
  const whatsappLinks = document.querySelectorAll('a[href^="https://wa.me/"]');

  whatsappLinks.forEach(link => {
    link.addEventListener('click', () => {
      fbq('track', 'Lead');
    });
  });
});
</script>


</BaseLayout>
