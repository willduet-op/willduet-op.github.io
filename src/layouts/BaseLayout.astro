---
import "../styles/global.css";

const { 
  title = "WILLDUET", 
  description = "WILLDUET helps US businesses build trusted Power BI dashboards, clean data pipelines, analytics engineering models, and practical data training.",
  canonicalPath = Astro.url.pathname,
  image = "/dashboard.jpg",
  lang = "en",
  robots = "index, follow",
  structuredData,
} = Astro.props;

const site = Astro.site ?? new URL("https://willduet.com");
const canonicalUrl = new URL(canonicalPath, site).toString();
const imageUrl = new URL(image, site).toString();
const isNoindex = robots.includes("noindex");
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="preload" href="/hero-image.webp" as="image" type="image/webp" />
    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="WILLDUET" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:locale" content={lang === "es" ? "es_DO" : "en_US"} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    {!isNoindex && structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}

    <slot name="head" /> 

    <script src="https://analytics.ahrefs.com/analytics.js" data-key="B3CMbZlIDvQaz3iMYwISRw" async></script>
    
    <!-- Meta Pixel Code -->
    <script is:inline>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '1288048266683928');
    fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=1288048266683928&ev=PageView&noscript=1"
    /></noscript>
    <!-- End Meta Pixel Code -->
    
  </head>
  <body>
    <slot />
  </body>
</html>
